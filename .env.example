# Copia este archivo a .env o exporta las variables antes de ejecutar la aplicación.
# Valores por defecto definidos en src/main/resources/application.yml

DB_HOST=localhost
DB_PORT=5432
DB_NAME=lumind
DB_USERNAME=lumind
DB_PASSWORD=lumind
SERVER_PORT=8080

# HMAC secret for JWT signing (minimum 256 bits / 32 bytes). Generate with:
# openssl rand -base64 32
JWT_SECRET=
